			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: 01 Revenue\Reseller (USD)
		lineageTag: 3cf15144-9ed1-4cb2-9e53-e2f530332f0e

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Reseller Average Selling Price (USD)' =
			
			DIVIDE (
			    [Reseller Revenue (USD)],
			    SUM ( FactResellerSales[OrderQuantity] )
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: 01 Revenue\Reseller (USD)
		lineageTag: 2e6be8ff-0720-4ac6-b72a-784bf78df0cb

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Reseller Discount % (USD)' =
			
			DIVIDE (
			    [Reseller Discount (USD)],
