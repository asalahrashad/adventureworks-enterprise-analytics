			)
		displayFolder: 01 Revenue\Reseller (USD)
		lineageTag: f074010f-1321-4982-9d15-58672c87b8f6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Revenue' =
			
