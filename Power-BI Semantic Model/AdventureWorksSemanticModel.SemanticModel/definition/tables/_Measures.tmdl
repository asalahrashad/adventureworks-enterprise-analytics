			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: 02 Profitability\Internet
		lineageTag: 39e26253-a324-4a3b-93da-60ed21717993

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Internet Gross Margin %' =
			
