		displayFolder: 02 Profitability\Internet
		lineageTag: 1786e5a6-4e70-40b0-a9c2-25fdc15ea9a3

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Reseller Cost' =
			
			SUM ( FactResellerSales[TotalProductCost] )
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: 02 Profitability\Reseller (USD)
		lineageTag: c55e587b-aa16-4634-b291-44d6bbc46c3f

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Reseller Gross Profit' =
			
