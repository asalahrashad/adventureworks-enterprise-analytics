		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Reseller Discount % (Local)' =
			
			DIVIDE (
			    [Reseller Discount (Local)],
			    [Reseller Revenue (Local)] + [Reseller Discount (Local)]
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: 01 Revenue\Reseller (Local)
		lineageTag: 5eabccd7-39c3-4f46-bfd5-b16af3acbcf5

	measure 'Reseller Revenue (USD)' =
			
			SUMX (
			    FactResellerSales,
			    FactResellerSales[SalesAmount]
			        * LOOKUPVALUE (
			            FactCurrencyRate[AverageRate],
			            FactCurrencyRate[CurrencyKey], FactResellerSales[CurrencyKey],
			            FactCurrencyRate[DateKey], FactResellerSales[OrderDateKey]
			        )
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: 01 Revenue\Reseller (USD)
		lineageTag: 365c8b8e-e5af-4406-bcf9-078610dc12bc

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Reseller Discount (USD)' =
			
			SUMX (
			    FactResellerSales,
			    FactResellerSales[DiscountAmount]
			        * LOOKUPVALUE (
			            FactCurrencyRate[AverageRate],
			            FactCurrencyRate[CurrencyKey], FactResellerSales[CurrencyKey],
			            FactCurrencyRate[DateKey], FactResellerSales[OrderDateKey]
			        )
			)
		displayFolder: 01 Revenue\Reseller (USD)
		lineageTag: ed3e741f-1114-4614-acf2-9deac5ddccc8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Reseller Average Order Value (USD)' =
			
			DIVIDE (
			    [Reseller Revenue (USD)],
